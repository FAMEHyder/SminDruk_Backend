# ==========================================
# Zarshan Backend - Environment Configuration
# ==========================================
# Copy this file to ".env" and replace every placeholder
# with your own values. NEVER commit the real ".env" file.

# ---------- Server ----------
PORT=8000
NODE_ENV=development

# ---------- URLs: Local (development) ----------
API_URL_LOCAL=http://localhost:8000
FRONTEND_URL_LOCAL=http://localhost:3000

# ---------- URLs: Live (Railway + Vercel) ----------
API_URL_LIVE=https://smindruk.up.railway.app
FRONTEND_URL_LIVE=https://smindruk.vercel.app

# Comma-separated extra CORS origins (both frontends are auto-included)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://smindruk.vercel.app

# Legacy fallbacks (optional — LOCAL/LIVE vars above take priority)
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ---------- Database ----------
MONGO_URL=your_mongodb_atlas_connection_string

# ---------- Authentication ----------
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ---------- Encryption (social account tokens at rest) ----------
ENCRYPTION_KEY=a_long_random_passphrase_used_to_encrypt_stored_oauth_tokens

# ---------- OAuth: Facebook ----------
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret
FB_CALLBACK_URL=http://localhost:8000/api/v1/auth/facebook/callback

# ---------- OAuth: Google ----------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback

# ---------- OAuth: GitHub ----------
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback

# ---------- Cloudinary (Media Storage) ----------
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ---------- OpenAI (AI Module) ----------
OPENAI_API_KEY=your_openai_api_key

# ---------- Email (Nodemailer) ----------
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USER=your_email_username
EMAIL_PASS=your_email_password
EMAIL_FROM=Zarshan <no-reply@zarshan.app>

# ---------- Payments ----------
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
